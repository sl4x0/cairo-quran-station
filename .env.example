# Cairo Quran Station - Environment Variables

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://sl4x0.github.io/cairo-quran-station

# Radio Stream Configuration
NEXT_PUBLIC_STREAM_URL=https://n01.radiojar.com/8s5u5tpdtwzuv

# RadioJar Real-Time Listener Count (Optional but Recommended)
# Get your station ID from RadioJar dashboard: https://www.radiojar.com/
# Example: If your stream URL is https://n01.radiojar.com/8s5u5tpdtwzuv
# Your station ID is likely: 8s5u5tpdtwzuv
NEXT_PUBLIC_RADIOJAR_STATION_ID=8s5u5tpdtwzuv

# Optional: RadioJar API Key for authenticated requests (provides higher rate limits)
# Get from: https://www.radiojar.com/developers
NEXT_PUBLIC_RADIOJAR_API_KEY=

# Note: API endpoints for Prayer Times and Quran are hardcoded in the app
# Prayer Times API: https://api.aladhan.com/v1/timingsByCity
# Quran API: https://api.alquran.cloud/v1/ayah

